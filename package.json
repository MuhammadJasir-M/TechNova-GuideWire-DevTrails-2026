{
  "name": "gigpulsesentinel",
  "version": "1.0.0",
  "description": "An AI-Powered Parametric Income Agent for Gig Workers",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "seed": "cd backend && python -m scripts.seed_data",
    "test": "cd backend && python -m pytest ../tests/ -v"
  },
  "keywords": [
    "gigpulsesentinel",
    "parametric-insurance",
    "gig-workers",
    "ai",
    "guidewire"
  ],
  "author": "TechNova",
  "license": "MIT"
}